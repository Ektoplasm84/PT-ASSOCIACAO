<%- include('../partials/header') %>
<% var pendingCount = invites.filter(function(i){ return i.status === 'pending'; }).length; %>

<div class="row mb-3 align-items-center">
  <div class="col">
    <h2 class="fw-bold"><%= t('profile.title') %></h2>
  </div>
  <div class="col-auto">
    <a href="/profile/edit" class="btn btn-primary">
      <i class="bi bi-pencil"></i> <%= t('profile.edit_btn') %>
    </a>
  </div>
</div>

<% if (feeReminder) { %>
<div class="alert alert-warning d-flex gap-2 align-items-start mb-4">
  <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
  <div><strong>Fee Reminder</strong> — <%= feeReminder %></div>
</div>
<% } %>

<div class="profile-layout">

  <div class="profile-sidebar text-center">
    <% if (member.photo_path) { %>
    <img src="/<%= member.photo_path.replace(/\\/g, '/') %>" alt="Photo"
         class="rounded-circle mb-3 shadow" style="width:130px;height:130px;object-fit:cover;">
    <% } else { %>
    <div class="text-muted mb-3"><i class="bi bi-person-circle" style="font-size:130px"></i></div>
    <% } %>
    <div class="fw-bold fs-5"><%= member.arc_name_en || (member.first_name + ' ' + member.last_name) %></div>
    <div class="text-muted small"><code><%= member.member_id %></code></div>
    <div class="mt-2">
      <% if (member.user_position === 'honorary') { %>
      <span class="badge bg-honorary"><i class="bi bi-star-fill me-1"></i><%= t('fee.status_honorary') %></span>
      <% } else { %>
      <span class="badge bg-<%= member.fee_status === 'paid' ? 'success' : member.fee_status === 'renewal_incoming' ? 'warning' : 'danger' %>">
        <%= member.fee_status === 'paid' ? t('fee.status_paid') : member.fee_status === 'renewal_incoming' ? t('fee.status_renewal') : t('fee.status_unpaid') %>
      </span>
      <% } %>
    </div>
  </div>

  <div class="profile-cards">

    <!-- 1. Personal Info -->
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold"><%= t('profile.section_personal') %></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.phone') %></span><div><%= member.phone || '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.email') %></span><div><%= member.email || '—' %></div></div>
          <div class="col-12"><span class="text-muted small"><%= t('profile.address_zh') %></span><div><%= member.address_zh || '—' %></div></div>
          <div class="col-12"><span class="text-muted small"><%= t('profile.address_en') %></span><div><%= member.address || '—' %></div></div>
        </div>
      </div>
    </div>

    <!-- 2. Membership Info -->
    <%
      const feeLabels = { paid: t('fee.status_paid'), unpaid: t('fee.status_unpaid'), renewal_incoming: t('fee.status_renewal') };
      const feeColors = { paid: 'success', unpaid: 'danger', renewal_incoming: 'warning' };
    %>
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold"><%= t('profile.section_membership') %></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.email') %></span><div><%= member.email %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.joined') %></span><div><%= member.join_date ? member.join_date.slice(0,10) : '—' %></div></div>
          <% if (member.user_position === 'honorary') { %>
          <div class="col-12">
            <span class="badge bg-honorary px-3 py-2">
              <i class="bi bi-star-fill me-1"></i><%= t('fee.status_honorary') %>
            </span>
          </div>
          <% } else { %>
          <div class="col-sm-4"><span class="text-muted small"><%= t('profile.fee_amount') %></span>
            <div><% if (member.fee_amount === 0) { %><%= t('fee.status_honorary') %><% } else { %><span data-esc-twd="<%= member.fee_amount || 300 %>"><span class="esc-amt"><%= member.fee_amount || 300 %></span> <span class="js-esc-twd">TWD</span></span><% } %></div>
          </div>
          <div class="col-sm-4"><span class="text-muted small"><%= t('fee.last_paid') %></span>
            <div><%= member.fee_last_paid ? member.fee_last_paid.slice(0,10) : '—' %></div>
          </div>
          <div class="col-sm-4"><span class="text-muted small"><%= t('profile.fee_valid_until') %></span>
            <div><%= member.fee_valid_until ? member.fee_valid_until.slice(0,10) : '—' %></div>
          </div>
          <div class="col-sm-12 mt-1"><span class="text-muted small"><%= t('profile.fee_status') %></span>
            <div>
              <span class="badge bg-<%= feeColors[member.fee_status] || 'secondary' %>">
                <%= feeLabels[member.fee_status] || member.fee_status %>
              </span>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- 3. ARC Data -->
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold"><%= t('profile.arc_data_title') %> <small class="text-muted fw-normal"><%= t('profile.arc_taiwan') %></small></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.arc_number') %></span><div><%= member.arc_number || '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.arc_chinese_name') %></span><div><%= member.arc_chinese_name || '—' %></div></div>
          <div class="col-12"><span class="text-muted small"><%= t('profile.arc_name_en') %></span><div><%= member.arc_name_en || '—' %></div></div>
          <div class="col-sm-4"><span class="text-muted small"><%= t('profile.arc_issue_date') %></span><div><%= member.arc_issue_date ? member.arc_issue_date.slice(0,10) : '—' %></div></div>
          <div class="col-sm-4"><span class="text-muted small"><%= t('profile.arc_expiry') %></span><div><% if (member.is_aprc) { %><span class="badge bg-info text-dark px-2 py-1"><%= t('profile.aprc_permanent') %></span><% } else { %><%= member.arc_expiry_date ? member.arc_expiry_date.slice(0,10) : '—' %><% } %></div></div>
          <div class="col-sm-4"><span class="text-muted small"><%= t('profile.passport_number') %></span><div><%= member.passport_number || '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.serial_number') %></span><div><%= member.arc_serial_number || '—' %></div></div>
        </div>
      </div>
    </div>

    <!-- 4. Cartão de Cidadão -->
    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold"><%= t('profile.section_cc') %></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.cc_number') %></span><div><%= member.cc_number || '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.cc_expiry') %></span><div><%= member.cc_expiry_date ? member.cc_expiry_date.slice(0,10) : '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.nif') %></span><div><%= member.nif || '—' %></div></div>
          <div class="col-sm-6"><span class="text-muted small"><%= t('profile.niss') %></span><div><%= member.niss || '—' %></div></div>
        </div>
      </div>
    </div>

    <!-- Notes (full-width) -->
    <% if (canWrite && member.notes) { %>
    <div class="card shadow-sm mb-3 full">
      <div class="card-header fw-semibold"><%= t('profile.notes_title') %></div>
      <div class="card-body">
        <p class="mb-0" style="white-space:pre-wrap"><%= member.notes %></p>
      </div>
    </div>
    <% } %>

    <!-- My Documents (full-width) -->
    <%
      const CARD_TYPES_U = ['arc_front', 'arc_back', 'cc_front', 'cc_back'];
      const CARD_LABELS_U = { arc_front: t('profile.card_arc_front'), arc_back: t('profile.card_arc_back'), cc_front: t('profile.card_cc_front'), cc_back: t('profile.card_cc_back') };
      const cardDocsU = {};
      documents.forEach(d => { if (CARD_TYPES_U.includes(d.doc_type)) cardDocsU[d.doc_type] = d; });
      const miscDocsU = documents.filter(d => !d.doc_type || d.doc_type === 'misc');
      const hasCardDocs = Object.keys(cardDocsU).length > 0;
    %>
    <div class="card shadow-sm full">
      <div class="card-header fw-semibold"><%= t('profile.my_documents') %></div>
      <div class="card-body">

        <% if (hasCardDocs) { %>
        <p class="text-uppercase text-muted small fw-semibold mb-2" style="letter-spacing:.05em"><%= t('profile.identity_cards') %></p>
        <div class="row g-2 mb-3">
          <% for (const [type, label] of Object.entries(CARD_LABELS_U)) { %>
          <%   const doc = cardDocsU[type]; %>
          <% if (doc) { %>
          <div class="col-6 col-md-3">
            <div class="border rounded p-2 text-center d-flex flex-column align-items-center" style="min-height:120px">
              <div class="small fw-semibold text-muted mb-1"><%= label %></div>
              <div class="flex-grow-1 d-flex align-items-center justify-content-center mb-1">
                <% if (doc.thumb_path) { %>
                <img src="/<%= doc.thumb_path.replace(/\\/g, '/') %>"
                     class="img-fluid rounded" style="max-height:65px;max-width:100%;object-fit:contain;cursor:pointer"
                     onclick="openImageModal('/profile/documents/<%= doc.id %>/view','/profile/documents/<%= doc.id %>/download','<%= label %>')"
                     title="Click to view">
                <% } else { %>
                <i class="bi bi-file-image text-secondary" style="font-size:2rem"></i>
                <% } %>
              </div>
              <a href="/profile/documents/<%= doc.id %>/download"
                 class="btn btn-outline-primary w-100" style="padding:2px 6px;font-size:.75rem">
                <i class="bi bi-download"></i> <%= t('vault.download_btn') %>
              </a>
            </div>
          </div>
          <% } %>
          <% } %>
        </div>
        <% if (miscDocsU.length) { %><hr class="my-2"><% } %>
        <% } %>

        <% if (miscDocsU.length) { %>
        <% if (hasCardDocs) { %><p class="text-uppercase text-muted small fw-semibold mb-2" style="letter-spacing:.05em"><%= t('profile.misc_docs') %></p><% } %>
        <ul class="list-group list-group-flush">
          <% miscDocsU.forEach(doc => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center px-0">
            <span class="d-flex align-items-center gap-2">
              <% if (doc.thumb_path) { %>
              <img src="/<%= doc.thumb_path.replace(/\\/g, '/') %>"
                   style="height:36px;width:36px;object-fit:cover;cursor:pointer" class="rounded border"
                   onclick="openImageModal('/profile/documents/<%= doc.id %>/view','/profile/documents/<%= doc.id %>/download','<%= doc.original_name %>')"
                   title="Click to view">
              <% } else { %>
              <i class="bi bi-file-earmark text-secondary fs-4"></i>
              <% } %>
              <span>
                <div class="small fw-semibold"><%= doc.original_name %></div>
                <div class="text-muted" style="font-size:.75rem"><%= doc.uploaded_at.slice(0,10) %></div>
              </span>
            </span>
            <a href="/profile/documents/<%= doc.id %>/download" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-download"></i>
            </a>
          </li>
          <% }) %>
        </ul>
        <% } else if (!hasCardDocs) { %>
        <p class="text-muted mb-0"><%= t('profile.no_my_documents') %></p>
        <% } %>

      </div>
    </div>

  </div>
</div><!-- /profile-layout -->

<div class="section-label" id="notifications">
  <i class="bi bi-bell"></i> <%= t('profile.section_notifications') %>
  <% if (pendingCount > 0) { %><span class="pta-badge pta-badge--solid pta-tone-danger" style="margin-left:.5rem"><%= pendingCount %></span><% } %>
</div>

  <% if (!invites.length) { %>
  <div class="pta-card">
    <div class="pta-card__body" style="text-align:center;padding:3rem 1rem;color:var(--text-muted)">
      <i class="bi bi-bell-slash" style="font-size:2rem"></i>
      <p class="mb-0 mt-2"><%= t('notify.no_notifications') %></p>
    </div>
  </div>
  <% } else { %>

  <%
    var pendingInvites  = invites.filter(function(i){ return i.status === 'pending'; });
    var answeredInvites = invites.filter(function(i){ return i.status !== 'pending'; });
  %>

  <% if (pendingInvites.length) { %>
  <h6 class="text-uppercase fw-semibold mb-3" style="letter-spacing:.05em;font-size:.75rem;color:var(--text-muted)">
    <%= t('notify.pending_heading') %> (<%= pendingInvites.length %>)
  </h6>
  <% pendingInvites.forEach(function(inv) { %>
  <div class="pta-invite" id="inv-<%= inv.id %>">
    <div class="pta-invite__rail" style="background:var(--event-<%= (inv.event_id % 8) + 1 %>)"></div>
    <div class="pta-invite__body">
      <div class="pta-invite__top">
        <div>
          <div class="pta-invite__title"><%= inv.title %></div>
          <div class="pta-invite__meta">
            <span><i class="bi bi-calendar-event"></i><span class="mono"><%= inv.start_date ? inv.start_date.slice(0,10) : '—' %><% if (inv.end_date) { %> → <%= inv.end_date.slice(0,10) %><% } %></span></span>
            <% if (inv.location) { %><span><i class="bi bi-geo-alt"></i><%= inv.location %></span><% } %>
          </div>
          <% if (inv.description) { %>
          <div class="pta-invite__desc"><%= inv.description %></div>
          <% } %>
        </div>
        <span class="pta-invite__status is-pending"><%= t('notify.pending') %></span>
      </div>
      <div class="pta-invite__actions">
        <button class="pta-btn pta-btn--sm js-respond" data-id="<%= inv.id %>" data-action="accepted"><i class="bi bi-check-lg"></i> <%= t('profile.invite_accept') %></button>
        <button class="pta-btn pta-btn--secondary pta-btn--sm js-respond" data-id="<%= inv.id %>" data-action="declined"><%= t('profile.invite_decline') %></button>
        <a class="pta-btn pta-btn--gold-soft pta-btn--sm" href="/profile/invites/<%= inv.id %>/export.ics" title="Download .ics for Apple Calendar, Google Calendar, Outlook…"><i class="bi bi-calendar-plus"></i> <%= t('profile.invite_add_cal') %></a>
      </div>
    </div>
  </div>
  <% }); %>
  <% } %>

  <% if (answeredInvites.length) { %>
  <% if (pendingInvites.length) { %><hr class="my-4"><% } %>
  <h6 class="text-uppercase fw-semibold mb-3" style="letter-spacing:.05em;font-size:.75rem;color:var(--text-muted)">
    <%= t('notify.previous_heading') %>
  </h6>
  <% answeredInvites.forEach(function(inv) { %>
  <div class="pta-invite is-resolved">
    <div class="pta-invite__rail" style="background:var(--event-<%= (inv.event_id % 8) + 1 %>)"></div>
    <div class="pta-invite__body">
      <div class="pta-invite__top">
        <div>
          <div class="pta-invite__title"><%= inv.title %></div>
          <div class="pta-invite__meta">
            <span><i class="bi bi-calendar-event"></i><span class="mono"><%= inv.start_date ? inv.start_date.slice(0,10) : '—' %></span></span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem">
          <span class="pta-invite__status is-<%= inv.status %>"><%= t('notify.' + inv.status) %></span>
          <% if (inv.status === 'accepted') { %>
          <a href="/profile/invites/<%= inv.id %>/export.ics" class="pta-btn pta-btn--ghost pta-btn--sm" title="Add to calendar"><i class="bi bi-calendar-plus"></i></a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
  <% } %>

  <% } %>

<div class="section-label" style="margin-top:2rem"><i class="bi bi-archive-fill" style="color:var(--green-600)"></i> <%= t('profile.section_documents') %></div>
<div class="pta-card pta-card--flush">
  <% if (!vaultFiles || !vaultFiles.length) { %>
  <div style="text-align:center;padding:2rem;color:var(--text-muted)">
    <i class="bi bi-archive" style="font-size:1.5rem;display:block;margin-bottom:.4rem"></i>
    <%= t('profile.no_documents') %>
  </div>
  <% } else { %>
  <div class="pta-table-wrap">
    <table class="pta-table">
      <thead><tr><th><%= t('vault.col_file') %></th><th><%= t('vault.col_desc') %></th><th><%= t('vault.col_date') %></th><th></th></tr></thead>
      <tbody>
        <% vaultFiles.forEach(function(f) {
          const ext = f.original_name.split('.').pop().toLowerCase();
          const ico = ext==='pdf' ? 'bi-file-earmark-pdf'
                    : ['jpg','jpeg','png','webp'].includes(ext) ? 'bi-file-earmark-image'
                    : ['doc','docx'].includes(ext) ? 'bi-file-earmark-word'
                    : 'bi-file-earmark';
        %>
        <tr>
          <td><i class="bi <%= ico %>" style="margin-right:.4rem;color:var(--text-muted)"></i>
            <span style="font-weight:500"><%= f.original_name %></span>
            <span class="pta-id" style="font-size:.75rem"><%= Math.round(f.file_size/1024) %> KB</span></td>
          <td style="color:var(--text-muted)"><%= f.description || '—' %></td>
          <td><span class="pta-id"><%= f.uploaded_at ? f.uploaded_at.slice(0,10) : '—' %></span></td>
          <td><a href="/vault/files/<%= f.id %>" class="pta-btn pta-btn--ghost pta-btn--sm"><i class="bi bi-download"></i></a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
(function () {
  // Respond to invite
  document.querySelectorAll('.js-respond').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id     = btn.dataset.id;
      var action = btn.dataset.action;
      btn.disabled = true;
      fetch('/profile/invites/' + id + '/respond', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: action }),
      })
        .then(function(r) {
          if (!r.ok) throw new Error('Server error ' + r.status);
          return r.json();
        })
        .then(function(d) {
          if (d.ok) {
            var card = document.getElementById('inv-' + id);
            if (card) {
              card.classList.add('is-resolved');
              var actionsEl = card.querySelector('.pta-invite__actions');
              if (actionsEl) actionsEl.remove();
              var statusEl = card.querySelector('.pta-invite__status');
              if (statusEl) {
                statusEl.className = 'pta-invite__status is-' + action;
                statusEl.textContent = action;
              }
            }
            // Update bell badge count
            var bellBadge = document.querySelector('.pta-bell__badge');
            if (bellBadge) {
              var n = parseInt(bellBadge.textContent, 10) - 1;
              if (n <= 0) bellBadge.remove();
              else bellBadge.textContent = String(n);
            }
          } else {
            btn.disabled = false;
            alert(d.error || 'Could not save your response. Please try again.');
          }
        })
        .catch(function(err) {
          btn.disabled = false;
          alert(err.message === 'Server error 401' || err.message.includes('401')
            ? 'Your session has expired. Please refresh the page and log in again.'
            : 'Could not save your response. Please try again.');
        });
    });
  });
}());
</script>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="imageViewModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title mb-0" id="imageViewModalTitle"></h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-2">
        <img id="imageViewModalImg" src="" alt="" class="img-fluid rounded" style="max-height:75vh">
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        <a id="imageViewModalDownload" href="#" class="btn btn-primary btn-sm">
          <i class="bi bi-download"></i> Download
        </a>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var _imgModal = null;
  function imgModal() {
    if (!_imgModal) _imgModal = new bootstrap.Modal(document.getElementById('imageViewModal'));
    return _imgModal;
  }
  window.openImageModal = function (viewUrl, downloadUrl, label) {
    document.getElementById('imageViewModalTitle').textContent = label;
    document.getElementById('imageViewModalImg').src = viewUrl;
    document.getElementById('imageViewModalDownload').href = downloadUrl;
    imgModal().show();
  };
})();
</script>

<%- include('../partials/footer') %>
