</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script>
(function () {
  /* Easter egg: click TWD 5× to convert the annual fee to Portuguese Escudos.
     1 EUR = 200.482 PTE (historical fixed rate); 1 EUR ≈ 34 TWD (approx). */
  var PTE_PER_EUR = 200.482;
  var TWD_PER_EUR = 34;

  function toEscudos(twd) {
    return Math.round(twd * PTE_PER_EUR / TWD_PER_EUR);
  }

  function fmtEsc(n) {
    /* Portuguese notation: 1.769$00 (period as thousands separator) */
    return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + '$00';
  }

  document.querySelectorAll('.js-esc-twd').forEach(function (el) {
    el.style.cursor = 'pointer';
    var clicks = 0;
    var inEsc   = false;
    var wrap    = el.closest('[data-esc-twd]');
    if (!wrap) return;
    var amtEl = wrap.querySelector('.esc-amt');
    if (!amtEl) return;
    var twd = parseInt(wrap.dataset.escTwd, 10);

    el.addEventListener('click', function () {
      if (++clicks % 5 !== 0) return;
      inEsc = !inEsc;
      if (inEsc) {
        amtEl.textContent = fmtEsc(toEscudos(twd));
        el.textContent    = 'ESCUDOS';
        el.title          = '1 EUR = 200.482 Esc. · 1 EUR ≈ 34 TWD';
      } else {
        amtEl.textContent = twd;
        el.textContent    = 'TWD';
        el.title          = '';
      }
    });
  });
}());
</script>
</body>
</html>
