<%
  const v = data || {};
  const isEdit = !!v.id;
%>

<!-- ── 1. Personal Info ──────────────────────────────────────── -->
<div class="card mb-3">
  <div class="card-header fw-semibold"><%= t('form.section_personal') %></div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label"><%= t('form.first_name') %> *</label>
        <input type="text" id="input_first_name" name="first_name" class="form-control" value="<%= v.first_name || '' %>" required>
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.last_name') %> *</label>
        <input type="text" id="input_last_name" name="last_name" class="form-control" value="<%= v.last_name || '' %>" required>
      </div>
      <% if (v.arc_name_en) {
           const _enFull       = v.arc_name_en.trim();
           const _enParts      = _enFull.split(/\s+/);
           const _enLast       = _enParts.length > 1 ? _enParts[_enParts.length - 1] : '';
           const _enFirst      = _enParts.length > 1 ? _enParts.slice(0, -1).join(' ') : _enFull;
           const _enIsPassport = v.residence_doc_type === 'tw_passport';
           const _enCurrent    = ((v.first_name || '') + ' ' + (v.last_name || '')).trim();
           if (_enFull !== _enCurrent) { %>
      <div class="col-12">
        <div class="alert alert-info py-2 mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-person-vcard"></i>
          <span><%= _enIsPassport ? t('form.passport_name_banner') : t('form.arc_name_banner') %>: <strong><%= v.arc_name_en %></strong></span>
          <button type="button" class="btn btn-sm btn-outline-primary ms-auto"
            data-arc-first="<%= _enFirst %>" data-arc-last="<%= _enLast %>"
            onclick="document.getElementById('input_first_name').value=this.dataset.arcFirst;document.getElementById('input_last_name').value=this.dataset.arcLast;">
            <%= _enIsPassport ? t('form.use_passport_name') : t('form.use_arc_name') %>
          </button>
        </div>
      </div>
      <% } } %>
      <% if (v.arc_chinese_name) {
           const _zhFull    = v.arc_chinese_name.trim();
           const _zhFirst   = _zhFull.length > 1 ? _zhFull.slice(1) : '';
           const _zhLast    = _zhFull.charAt(0);
           const _zhSplit   = (_zhFirst + ' ' + _zhLast).trim();
           const _zhCurrent = ((v.first_name || '') + ' ' + (v.last_name || '')).trim();
           if (_zhSplit !== _zhCurrent) { %>
      <div class="col-12">
        <div class="alert alert-secondary py-2 mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-translate"></i>
          <span><%= t('form.zh_name_banner') %>: <strong><%= v.arc_chinese_name %></strong></span>
          <button type="button" class="btn btn-sm btn-outline-secondary ms-auto"
            data-zh-first="<%= _zhFirst %>" data-zh-last="<%= _zhLast %>"
            onclick="document.getElementById('input_first_name').value=this.dataset.zhFirst;document.getElementById('input_last_name').value=this.dataset.zhLast;">
            <%= t('form.use_zh_name') %>
          </button>
        </div>
      </div>
      <% } } %>
      <%
        const _phoneMatch = (v.phone || '').match(/^(\+\d+)\s(.+)$/);
        const _phoneDial  = _phoneMatch ? _phoneMatch[1] : '+351';
        const _phoneNum   = _phoneMatch ? _phoneMatch[2] : (v.phone || '');
      %>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.phone') %></label>
        <%- include('phone-field', { dialCode: _phoneDial, phoneNum: _phoneNum, countries: countries }) %>
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.email') %> *</label>
        <input type="email" name="email" class="form-control" value="<%= v.email || '' %>" required>
      </div>
      <div class="col-12">
        <label class="form-label"><%= t('form.address_zh') %></label>
        <input type="text" name="address_zh" class="form-control" value="<%= v.address_zh || '' %>"
               placeholder="e.g. 臺北市大安區信義路四段1號">
        <div class="form-text"><%= t('form.address_zh_hint') %></div>
      </div>
      <div class="col-12">
        <label class="form-label"><%= t('form.address_en') %></label>
        <input type="text" name="address" class="form-control" value="<%= v.address || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.degree') %></label>
        <input type="text" name="degree" class="form-control" value="<%= v.degree || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.university') %></label>
        <input type="text" name="university" class="form-control" value="<%= v.university || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.profession') %></label>
        <input type="text" name="profession" class="form-control" value="<%= v.profession || '' %>">
      </div>
      <div class="col-12">
        <label class="form-label"><%= t('form.photo') %></label>
        <% if (isEdit && v.photo_path) { %>
        <div class="mb-2">
          <img src="/<%= v.photo_path.replace(/\\/g, '/') %>" alt="Current photo"
               class="rounded" style="height:80px;width:80px;object-fit:cover;">
          <small class="text-muted ms-2"><%= t('form.photo_replace_hint') %></small>
        </div>
        <% } %>
        <input type="file" name="photo" class="form-control" accept="image/jpeg,image/png,image/webp">
        <div class="form-text"><%= t('form.photo_hint') %></div>
      </div>
    </div>
  </div>
</div>

<!-- ── 2. Membership Info ────────────────────────────────────── -->
<%
  const feeStatusLabels = { paid: t('fee.status_paid'), unpaid: t('fee.status_unpaid'), renewal_incoming: t('fee.status_renewal') };
  const feeStatusColors = { paid: 'success', unpaid: 'danger', renewal_incoming: 'warning' };
  const currentFeeStatus = v.fee_status || 'unpaid';
  const isHonoraryForm = v.user_position === 'honorary';
%>
<div class="card mb-3">
  <div class="card-header fw-semibold"><%= t('form.section_membership') %></div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label"><%= isEdit ? t('form.password_edit') : t('form.password_new') + ' *' %></label>
        <input type="password" name="<%= isEdit ? 'new_password' : 'password' %>" class="form-control"
          <% if (!isEdit) { %>required<% } %> minlength="6" autocomplete="new-password">
      </div>
      <% if (isEdit) { %>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.member_id') %></label>
        <input type="text" class="form-control" value="<%= v.member_id %>" disabled>
      </div>
      <% } %>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.join_date') %></label>
        <input type="date" name="join_date" class="form-control"
          value="<%= v.join_date ? v.join_date.slice(0,10) : new Date().toISOString().slice(0,10) %>">
      </div>

      <!-- Fee fields -->
      <% if (isHonoraryForm) { %>
      <div class="col-12">
        <div class="alert alert-secondary py-2 mb-0 d-flex align-items-center gap-2">
          <i class="bi bi-star-fill text-honorary"></i>
          <span><%= t('form.honorary_notice') %></span>
        </div>
      </div>
      <% } else { %>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.annual_fee') %></label>
        <%
          const _feeRaw   = parseInt(v.fee_amount);
          const _stdFee   = (typeof defaultFee !== 'undefined' && !isNaN(parseInt(defaultFee))) ? parseInt(defaultFee) : 300;
          const _feeIsZero = !isNaN(_feeRaw) && _feeRaw === 0;
          const _feeDisplay = (!isNaN(_feeRaw) && _feeRaw > 0) ? _feeRaw : _stdFee;
        %>
        <select name="fee_amount" class="form-select">
          <option value="<%= _feeDisplay %>" <%= !_feeIsZero ? 'selected' : '' %>><%= _feeDisplay %> TWD</option>
          <option value="0" <%= _feeIsZero ? 'selected' : '' %>><%= t('fee.honorary_option') %></option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.date_last_paid') %></label>
        <input type="date" name="fee_last_paid" class="form-control"
          value="<%= v.fee_last_paid ? v.fee_last_paid.slice(0,10) : '' %>">
        <div class="form-text"><%= t('form.date_last_paid_hint') %></div>
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.valid_until') %> <small class="text-muted"><%= t('form.auto') %></small></label>
        <input type="text" class="form-control"
          value="<%= v.fee_valid_until ? v.fee_valid_until.slice(0,10) : '—' %>" disabled>
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.fee_status') %> <small class="text-muted"><%= t('form.auto') %></small></label>
        <div class="mt-1">
          <span class="badge fs-6 bg-<%= feeStatusColors[currentFeeStatus] || 'secondary' %>">
            <%= feeStatusLabels[currentFeeStatus] || currentFeeStatus %>
          </span>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ── 3. ARC / APRC / Taiwan Passport / TW National ID ──────── -->
<%
  const _isAprc       = !!(v.is_aprc       && v.is_aprc       != '0');
  const _isTwPassport = !!(v.is_tw_passport && v.is_tw_passport != '0');
  const _isTwId       = !!(v.is_tw_id       && v.is_tw_id       != '0');
  const _docType      = _isAprc ? 'aprc' : _isTwPassport ? 'tw_passport' : _isTwId ? 'tw_id' : 'arc';
%>
<div class="card mb-3">
  <div class="card-header fw-semibold">
    <%= t('form.section_arc') %>
    <small class="text-muted fw-normal"><%= t('form.section_arc_sub') %></small>
  </div>

  <div class="card-body">
    <div class="row g-3">
      <!-- Document type selector -->
      <div class="col-12">
        <label class="form-label fw-semibold mb-1"><%= t('form.doc_type') %></label>
        <div class="pta-seg w-100" role="group">
          <input type="radio" class="btn-check" name="residence_doc_type" id="docTypeArc"
                 value="arc" <%= _docType === 'arc' ? 'checked' : '' %> onchange="arcDocTypeChanged()">
          <label class="pta-seg__opt" for="docTypeArc"><i class="bi bi-credit-card-fill"></i> ARC</label>
          <input type="radio" class="btn-check" name="residence_doc_type" id="docTypeAprc"
                 value="aprc" <%= _docType === 'aprc' ? 'checked' : '' %> onchange="arcDocTypeChanged()">
          <label class="pta-seg__opt" for="docTypeAprc"><i class="bi bi-shield-fill-check"></i> APRC</label>
          <input type="radio" class="btn-check" name="residence_doc_type" id="docTypeTwPassport"
                 value="tw_passport" <%= _docType === 'tw_passport' ? 'checked' : '' %> onchange="arcDocTypeChanged()">
          <label class="pta-seg__opt" for="docTypeTwPassport"><i class="bi bi-passport-fill"></i> TW Passport</label>
          <input type="radio" class="btn-check" name="residence_doc_type" id="docTypeTwId"
                 value="tw_id" <%= _docType === 'tw_id' ? 'checked' : '' %> onchange="arcDocTypeChanged()">
          <label class="pta-seg__opt" for="docTypeTwId"><i class="bi bi-person-vcard-fill"></i> TW ID</label>
        </div>
      </div>
      <!-- ARC / APRC number — hidden for tw_passport and tw_id -->
      <div class="col-md-6" id="arcNumWrap" <%= (_docType === 'tw_passport' || _docType === 'tw_id') ? 'style="display:none"' : '' %>>
        <label class="form-label"><%= t('form.arc_number') %></label>
        <input type="text" name="arc_number" class="form-control" value="<%= v.arc_number || '' %>">
      </div>
      <!-- TW National ID number — shown for tw_id and tw_passport (both have 統一編號) -->
      <div class="col-md-6" id="twIdNumWrap" <%= (_docType !== 'tw_id' && _docType !== 'tw_passport') ? 'style="display:none"' : '' %>>
        <label class="form-label"><%= t('form.tw_id_number') %></label>
        <input type="text" name="tw_id_number" class="form-control" value="<%= v.tw_id_number || '' %>">
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.chinese_name') %></label>
        <input type="text" name="arc_chinese_name" class="form-control" value="<%= v.arc_chinese_name || '' %>">
      </div>
      <!-- English name — hidden for tw_id (TW ID has no English name field) -->
      <div class="col-12" id="arcNameEnWrap" <%= _docType === 'tw_id' ? 'style="display:none"' : '' %>>
        <label class="form-label" id="arcNameEnLabel"><%= _docType === 'tw_passport' ? t('form.passport_english_name') : t('form.arc_english_name') %></label>
        <input type="text" name="arc_name_en" class="form-control" value="<%= v.arc_name_en || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.issue_date') %></label>
        <input type="date" name="arc_issue_date" class="form-control"
          value="<%= v.arc_issue_date ? v.arc_issue_date.slice(0,10) : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label" id="arcExpiryLabel"><%= _docType === 'tw_passport' ? t('form.passport_expiry') : t('form.expiry_date') %></label>
        <div id="arcExpiryInput" class="<%= (_docType === 'aprc' || _docType === 'tw_id') ? 'd-none' : '' %>">
          <input type="date" name="arc_expiry_date" id="arcExpiryDate" class="form-control"
            value="<%= (_docType !== 'aprc' && _docType !== 'tw_id') && v.arc_expiry_date ? v.arc_expiry_date.slice(0,10) : '' %>">
        </div>
        <div id="arcExpiryPermanent" class="<%= (_docType === 'aprc' || _docType === 'tw_id') ? '' : 'd-none' %>">
          <span class="badge bg-info text-dark px-3 py-2 fs-6"><%= _docType === 'tw_id' ? t('form.tw_id_permanent') : t('form.aprc_permanent') %></span>
        </div>
      </div>
      <!-- Passport number — hidden for tw_id -->
      <div class="col-md-4" id="passportNumWrap" <%= _docType === 'tw_id' ? 'style="display:none"' : '' %>>
        <label class="form-label" id="passportLabel"><%= _docType === 'tw_passport' ? t('form.tw_passport_number') : t('form.passport_number') %></label>
        <input type="text" name="passport_number" class="form-control" value="<%= v.passport_number || '' %>">
      </div>
      <!-- Serial number — shown only for arc and aprc -->
      <div class="col-md-6" id="arcSerialWrap" <%= (_docType === 'tw_passport' || _docType === 'tw_id') ? 'style="display:none"' : '' %>>
        <label class="form-label"><%= t('form.serial_number') %></label>
        <input type="text" name="arc_serial_number" class="form-control" value="<%= v.arc_serial_number || '' %>">
      </div>
      <!-- DOB + gender — shown for all doc types -->
      <div class="col-md-4">
        <label class="form-label"><%= t('form.date_of_birth') %></label>
        <input type="date" name="date_of_birth" class="form-control"
          value="<%= v.date_of_birth ? v.date_of_birth.slice(0,10) : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label"><%= t('form.gender') %></label>
        <select name="gender" class="form-select">
          <option value="" <%= !v.gender ? 'selected' : '' %>>—</option>
          <option value="男" <%= v.gender === '男' ? 'selected' : '' %>>男</option>
          <option value="女" <%= v.gender === '女' ? 'selected' : '' %>>女</option>
        </select>
      </div>
      <!-- Place of birth — TW ID / TW Passport only (printed on those documents) -->
      <div class="col-md-4" id="birthplaceTwWrap" <%= (_docType !== 'tw_id' && _docType !== 'tw_passport') ? 'style="display:none"' : '' %>>
        <label class="form-label"><%= t('form.birthplace_tw') %></label>
        <input type="text" name="birthplace_tw" class="form-control" value="<%= v.birthplace_tw || '' %>"
               placeholder="e.g. 臺灣省花蓮縣">
      </div>
    </div>
  </div>
</div>
<script>
function arcDocTypeChanged() {
  var type            = document.querySelector('input[name="residence_doc_type"]:checked').value;
  var dateInput       = document.getElementById('arcExpiryDate');
  var inputWrap       = document.getElementById('arcExpiryInput');
  var permBadge       = document.getElementById('arcExpiryPermanent');
  var expiryLbl       = document.getElementById('arcExpiryLabel');
  var passLbl         = document.getElementById('passportLabel');
  var arcNumWrap      = document.getElementById('arcNumWrap');
  var twIdNumWrap     = document.getElementById('twIdNumWrap');
  var passNumWrap     = document.getElementById('passportNumWrap');
  var serialWrap      = document.getElementById('arcSerialWrap');
  var arcNameEnWrap   = document.getElementById('arcNameEnWrap');
  var arcNameEnLabel  = document.getElementById('arcNameEnLabel');
  var birthplaceTwWrap= document.getElementById('birthplaceTwWrap');

  // Expiry: permanent for aprc and tw_id
  if (type === 'aprc' || type === 'tw_id') {
    inputWrap.classList.add('d-none');
    permBadge.classList.remove('d-none');
    dateInput.disabled = true;
    permBadge.querySelector('span').textContent = type === 'tw_id'
      ? '<%= t("form.tw_id_permanent") %>'
      : '<%= t("form.aprc_permanent") %>';
  } else {
    inputWrap.classList.remove('d-none');
    permBadge.classList.add('d-none');
    dateInput.disabled = false;
  }

  expiryLbl.textContent = type === 'tw_passport' ? '<%= t("form.passport_expiry") %>' : '<%= t("form.expiry_date") %>';
  if (passLbl) passLbl.textContent = type === 'tw_passport' ? '<%= t("form.tw_passport_number") %>' : '<%= t("form.passport_number") %>';

  var isTwId           = type === 'tw_id';
  var isTwIdOrPassport = (type === 'tw_id' || type === 'tw_passport');

  // Show/hide dedicated field groups
  arcNumWrap.style.display      = isTwIdOrPassport ? 'none' : '';
  twIdNumWrap.style.display     = isTwIdOrPassport ? '' : 'none';
  passNumWrap.style.display     = isTwId ? 'none' : '';
  serialWrap.style.display      = isTwIdOrPassport ? 'none' : '';
  arcNameEnWrap.style.display   = isTwId ? 'none' : '';
  if (arcNameEnLabel) arcNameEnLabel.textContent = type === 'tw_passport'
    ? '<%= t("form.passport_english_name") %>'
    : '<%= t("form.arc_english_name") %>';
  // birthplace — only on TW ID / Passport cards; DOB + gender are on all doc types (always visible)
  birthplaceTwWrap.style.display= isTwIdOrPassport ? '' : 'none';
}
</script>

<!-- ── 4. Cartão de Cidadão ──────────────────────────────────── -->
<div class="card mb-3">
  <div class="card-header fw-semibold"><%= t('form.section_cc') %> <small class="text-muted fw-normal"><%= t('form.section_cc_sub') %></small></div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label"><%= t('form.cc_number') %></label>
        <input type="text" name="cc_number" class="form-control" value="<%= v.cc_number || '' %>">
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.expiry_date') %></label>
        <input type="date" name="cc_expiry_date" class="form-control"
          value="<%= v.cc_expiry_date ? v.cc_expiry_date.slice(0,10) : '' %>">
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.nif') %> <small class="text-muted"><%= t('form.nif_full') %></small></label>
        <input type="text" name="nif" class="form-control" value="<%= v.nif || '' %>">
      </div>
      <div class="col-md-6">
        <label class="form-label"><%= t('form.niss') %> <small class="text-muted"><%= t('form.niss_full') %></small></label>
        <input type="text" name="niss" class="form-control" value="<%= v.niss || '' %>">
      </div>
    </div>
  </div>
</div>

<!-- ── 5. Notes ──────────────────────────────────────────────── -->
<div class="card mb-3">
  <div class="card-header fw-semibold"><%= t('form.section_notes') %></div>
  <div class="card-body">
    <textarea name="notes" class="form-control" rows="4" placeholder="<%= t('form.notes_placeholder') %>"><%= v.notes || '' %></textarea>
  </div>
</div>
