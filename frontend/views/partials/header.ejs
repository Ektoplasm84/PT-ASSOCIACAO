<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> — PT Associação</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css" integrity="sha384-aQuvIWWIbpu/mSqULLDiUveyYiPoJzPKAWjUmGJ+Elm+N/LJhzfZqsutsfw870JS" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/ds/pt-design-system.css">
  <link rel="stylesheet" href="/css/ds/pt-bootstrap-bridge.css">
</head>
<body>

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<%
  const _navActive = title === 'Dashboard' ? 'dashboard'
    : title === 'Audit Log' ? 'audit'
    : title === 'Public Documents' ? 'vault'
    : 'members';
%>
<header class="pta-topbar">
  <a class="pta-brand" href="/">
    <img src="/images/logo-emblem.png" width="38" height="38" alt="">
    <span class="pta-brand__txt">
      <span class="pta-brand__name">Associação Cultural Portuguesa</span>
      <span class="pta-brand__sub">na Formosa</span>
    </span>
  </a>

  <% if (canViewAll) { %>
  <nav class="pta-nav">
    <a class="pta-nav__item <%= _navActive === 'dashboard' ? 'is-active' : '' %>" href="/admin"><i class="bi bi-speedometer2"></i><span><%= t('nav.dashboard') %></span></a>
    <a class="pta-nav__item <%= _navActive === 'members'   ? 'is-active' : '' %>" href="/admin/members"><i class="bi bi-people-fill"></i><span><%= t('nav.members') %></span></a>
    <a class="pta-nav__item <%= _navActive === 'vault'     ? 'is-active' : '' %>" href="/vault"><i class="bi bi-archive-fill"></i><span><%= t('nav.documents') %></span></a>
    <% if (canWrite) { %>
    <a class="pta-nav__item <%= _navActive === 'audit'     ? 'is-active' : '' %>" href="/admin/audit"><i class="bi bi-clock-history"></i><span><%= t('nav.audit_log') %></span></a>
    <a class="pta-nav__item <%= _navActive === 'export'    ? 'is-active' : '' %>" href="/admin/export"><i class="bi bi-box-arrow-up"></i><span><%= t('nav.export') %></span></a>
    <% } %>
  </nav>
  <% } else { %>
  <nav class="pta-nav">
    <a class="pta-nav__item <%= title === 'My Profile' ? 'is-active' : '' %>" href="/profile"><i class="bi bi-person-circle"></i><span><%= t('nav.my_profile') %></span></a>
  </nav>
  <% } %>

  <div class="pta-topbar__right">
    <% if (currentUser.role === 'super_admin') { %>
    <span class="pta-badge pta-badge--solid pta-tone-danger"><%= t('nav.super_admin') %> <span style="opacity:.55;font-size:.8em;letter-spacing:.03em">v1.8</span></span>
    <% } else if (currentUser.role === 'admin') { %>
    <span class="pta-badge pta-badge--solid pta-tone-gold"><%= t('nav.admin') %></span>
    <% } %>
    <% if (currentUser.role === 'super_admin') { %>
    <button class="pta-topbar__bell pta-console-toggle" id="pta-console-btn" type="button" title="<%= t('nav.server_logs') %>">
      <i class="bi bi-terminal-fill"></i>
    </button>
    <% } %>
    <a href="/profile#notifications" class="pta-topbar__bell" title="<%= t('nav.notifications') %>">
      <i class="bi bi-bell<%= pendingInviteCount > 0 ? '-fill' : '' %>"></i>
      <% if (pendingInviteCount > 0) { %>
      <span class="pta-bell__badge"><%= pendingInviteCount %></span>
      <% } %>
    </a>
    <nav class="pta-langsw" aria-label="Language">
      <a href="/lang/en"    class="pta-langsw__btn<%= lang === 'en'    ? ' pta-langsw__btn--active' : '' %>" title="English"><span class="fi fi-gb"></span></a>
      <a href="/lang/pt"    class="pta-langsw__btn<%= lang === 'pt'    ? ' pta-langsw__btn--active' : '' %>" title="Português"><span class="fi fi-pt"></span></a>
      <a href="/lang/zh-TW" class="pta-langsw__btn<%= lang === 'zh-TW' ? ' pta-langsw__btn--active' : '' %>" title="中文"><span class="fi fi-tw"></span></a>
    </nav>
    <span class="pta-user">
      <span class="pta-user__email"><%= currentUser.email %></span>
      <% if (currentUser.role === 'member') { %>
      <a href="/profile/edit" class="pta-user__logout" title="<%= t('nav.edit_profile') %>"><i class="bi bi-pencil"></i></a>
      <% } %>
      <form action="/logout" method="POST" class="d-inline">
        <button class="pta-user__logout" type="submit" title="<%= t('nav.logout') %>"><i class="bi bi-box-arrow-right"></i></button>
      </form>
    </span>
  </div>
</header>

<% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'super_admin') { %>
<script>
(function () {
  var btn = document.getElementById('pta-console-btn');
  var win = null;
  btn.addEventListener('click', function () {
    if (win && !win.closed) { win.focus(); return; }
    win = window.open('/admin/logs', 'pta-server-logs',
      'width=960,height=520,resizable=yes,scrollbars=no,toolbar=no,menubar=no,location=no,status=no');
    if (win) win.focus();
  });
}());
</script>
<% } %>

<% } %>

<main class="pta-main">
  <%- include('flash') %>
