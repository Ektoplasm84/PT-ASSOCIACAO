<%- include('../partials/header') %>

<div class="row mb-3">
  <div class="col">
    <h2 class="fw-bold">Edit — <%= member.arc_name_en || (member.first_name + ' ' + member.last_name) %></h2>
  </div>
  <div class="col-auto">
    <a href="/admin/members/<%= member.id %>" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Back
    </a>
  </div>
</div>

<% if (errors.length) { %>
<div class="alert alert-danger">
  <ul class="mb-0">
    <% errors.forEach(e => { %><li><%= e %></li><% }) %>
  </ul>
</div>
<% } %>

<div class="card shadow-sm">
  <div class="card-body">
    <form action="/admin/members/<%= member.id %>" method="POST" enctype="multipart/form-data" novalidate>
      <%- include('../partials/member-form', { data: member, countries: countries, taiwanLocations: taiwanLocations }) %>
      <hr>
      <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem">
        <button type="submit" class="pta-btn pta-btn--lg">
          <i class="bi bi-floppy-fill"></i> Save Changes
        </button>
        <a href="/admin/members/<%= member.id %>" class="pta-btn pta-btn--secondary pta-btn--lg">
          <i class="bi bi-x-lg"></i> Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
