<%- include('../partials/header') %>

<%
  const ACTION_LABELS = {
    'member.created':       { label: 'Member Created',    icon: 'bi-person-plus-fill',  color: 'success' },
    'member.updated':       { label: 'Member Updated',    icon: 'bi-pencil-fill',        color: 'info'    },
    'member.deleted':       { label: 'Member Deleted',    icon: 'bi-person-x-fill',     color: 'danger'  },
    'member.role_changed':  { label: 'Role Changed',      icon: 'bi-shield-fill',        color: 'gold'    },
    'member.card_uploaded': { label: 'Card Uploaded',     icon: 'bi-credit-card-fill',   color: 'info'    },
    'member.doc_uploaded':  { label: 'Doc Uploaded',      icon: 'bi-file-earmark-plus',  color: 'info'    },
    'member.doc_deleted':   { label: 'Doc Deleted',       icon: 'bi-file-earmark-x',    color: 'danger'  },
    'member.ocr_applied':   { label: 'OCR Fields Applied','icon': 'bi-scan',             color: 'neutral' },
    'member.nia_photo_saved':{ label: 'NIA Photo Saved',  icon: 'bi-camera-fill',        color: 'neutral' },
    'profile.self_updated':  { label: 'Self-Updated Profile', icon: 'bi-person-fill',    color: 'info'    },
    'member.fee_updated':    { label: 'Fee Updated',          icon: 'bi-cash-stack',      color: 'success' },
    'vault.upload':          { label: 'Vault Upload',         icon: 'bi-archive-fill',    color: 'info'    },
    'vault.delete':          { label: 'Vault Delete',         icon: 'bi-archive',         color: 'danger'  },
    'member.password_reset': { label: 'Password Reset',       icon: 'bi-key-fill',        color: 'gold'    },
  };
%>

<div class="pta-pagehead">
  <div class="pta-pagehead__titles">
    <h1><i class="bi bi-journal-text"></i> <%= t('audit.title') %></h1>
    <span class="pta-pagehead__sub"><%= total %> <%= total === 1 ? t('audit.total_entry') : t('audit.total_entries') %></span>
  </div>
</div>

<% if (!logs.length) { %>
<div class="pta-card"><div class="pta-card__body" style="color:var(--text-muted)">
  <i class="bi bi-check-circle" style="color:var(--success)"></i> <%= t('audit.no_entries') %>
</div></div>
<% } else { %>
<div class="pta-card pta-card--flush">
  <div class="table-responsive">
    <table class="table table-sm table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t('audit.col_timestamp') %></th>
          <th><%= t('audit.col_actor') %></th>
          <th><%= t('audit.col_member') %></th>
          <th><%= t('audit.col_action') %></th>
          <th><%= t('audit.col_detail') %></th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach(log => {
          const meta = ACTION_LABELS[log.action] || { label: log.action, icon: 'bi-circle', color: 'neutral' };
        %>
        <tr>
          <td class="text-muted small text-nowrap"><%= log.created_at ? log.created_at.replace('T',' ').slice(0,19) : '—' %></td>
          <td>
            <span class="small"><%= log.actor_email || '—' %></span>
          </td>
          <td>
            <% if (log.member_id) { %>
            <a href="/admin/members/<%= log.member_id %>" class="small text-decoration-none">
              <%= log.member_ref || `member #${log.member_id}` %>
            </a>
            <% } else { %>
            <span class="text-muted small"><%= log.member_ref || '—' %></span>
            <% } %>
          </td>
          <td>
            <span class="pta-badge pta-badge--soft pta-tone-<%= meta.color %>">
              <i class="<%= meta.icon %>"></i>
              <%= meta.label %>
            </span>
          </td>
          <td class="small text-muted"><%= log.detail || '' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="/admin/audit?page=<%= page - 1 %>">‹ Prev</a>
    </li>
    <% for (let p = 1; p <= totalPages; p++) { %>
    <% if (p === 1 || p === totalPages || Math.abs(p - page) <= 2) { %>
    <li class="page-item <%= p === page ? 'active' : '' %>">
      <a class="page-link" href="/admin/audit?page=<%= p %>"><%= p %></a>
    </li>
    <% } else if (Math.abs(p - page) === 3) { %>
    <li class="page-item disabled"><span class="page-link">…</span></li>
    <% } %>
    <% } %>
    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="/admin/audit?page=<%= page + 1 %>">Next ›</a>
    </li>
  </ul>
</nav>
<% } %>

<% } %>

<%- include('../partials/footer') %>
