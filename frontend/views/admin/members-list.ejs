<%- include('../partials/header') %>

<%
  var sort = (typeof sort !== 'undefined') ? sort : 'name_az';
  function feeBadge(status) {
    if (status === 'paid')
      return '<span class="pta-badge pta-badge--soft pta-tone-success"><span class="pta-badge__dot"></span>Paid</span>';
    if (status === 'renewal_incoming')
      return '<span class="pta-badge pta-badge--soft pta-tone-gold"><span class="pta-badge__dot"></span>Renewal incoming</span>';
    if (status === 'unpaid')
      return '<span class="pta-badge pta-badge--soft pta-tone-danger"><span class="pta-badge__dot"></span>Unpaid</span>';
    return '<span class="pta-badge pta-badge--soft pta-tone-honorary">Honorary Member</span>';
  }
%>

<div class="pta-pagehead">
  <div class="pta-pagehead__titles">
    <h1>Members <span style="font-size:1rem;font-weight:400;color:var(--text-muted)">(<%= total %>)</span></h1>
  </div>
  <% if (canWrite) { %>
  <a href="/admin/members/new" class="pta-btn"><i class="bi bi-person-plus"></i> New Member</a>
  <% } %>
</div>

<%
  function memberListUrl(overrides) {
    var p = { search: search, fee: feeFilter, sort: sort };
    Object.assign(p, overrides);
    var qs = [];
    if (p.search) qs.push('search=' + encodeURIComponent(p.search));
    if (p.fee)    qs.push('fee='    + encodeURIComponent(p.fee));
    if (p.sort && p.sort !== 'name_az') qs.push('sort=' + p.sort);
    return '/admin/members' + (qs.length ? '?' + qs.join('&') : '');
  }
%>
<div class="pta-toolbar">
  <form method="GET" action="/admin/members" class="pta-search">
    <i class="bi bi-search"></i>
    <input class="pta-control" name="search" placeholder="Search name, ID or email…" value="<%= search %>">
    <% if (feeFilter) { %><input type="hidden" name="fee" value="<%= feeFilter %>"><% } %>
    <% if (sort && sort !== 'name_az') { %><input type="hidden" name="sort" value="<%= sort %>"><% } %>
  </form>
  <select class="form-select form-select-sm" style="width:auto;min-width:9rem"
          onchange="location.href=this.value" aria-label="Sort order">
    <% [
      ['name_az',     'Name A → Z'],
      ['name_za',     'Name Z → A'],
      ['newest',      'Recently Added'],
      ['oldest',      'Oldest First'],
      ['joined_desc', 'Join Date ↓'],
      ['joined_asc',  'Join Date ↑'],
    ].forEach(function(opt) { %>
    <option value="<%= memberListUrl({ sort: opt[0] }) %>"
            <%= sort === opt[0] ? 'selected' : '' %>><%= opt[1] %></option>
    <% }); %>
  </select>
  <div class="pta-filterchips">
    <a href="<%= memberListUrl({ fee: '' }) %>"
       class="pta-chip <%= !feeFilter ? 'is-active' : '' %>">All</a>
    <a href="<%= memberListUrl({ fee: 'paid' }) %>"
       class="pta-chip <%= feeFilter === 'paid' ? 'is-active' : '' %>">Paid</a>
    <a href="<%= memberListUrl({ fee: 'renewal_incoming' }) %>"
       class="pta-chip <%= feeFilter === 'renewal_incoming' ? 'is-active' : '' %>">Renewal</a>
    <a href="<%= memberListUrl({ fee: 'unpaid' }) %>"
       class="pta-chip <%= feeFilter === 'unpaid' ? 'is-active' : '' %>">Unpaid</a>
  </div>
</div>

<div class="pta-card pta-card--flush">
  <table class="pta-table">
    <thead>
      <tr>
        <th>Member</th>
        <th>Member ID</th>
        <th>Email</th>
        <th>Position</th>
        <th>ID Type</th>
        <th>Fee Status</th>
        <th>Warnings</th>
        <th>Joined</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% members.forEach(function(m) {
        const _initials = ((m.arc_name_en || (m.first_name + ' ' + m.last_name)) || '?')
          .trim().split(/\s+/).map(function(s){return s[0]||'';}).slice(0,2).join('').toUpperCase();
        const _roleLabels = { super_admin: 'Super Admin', admin: 'Admin' };
        const _posLabels  = { honorary: 'Honorary Member', gestao: 'Gestão',
                              board: 'Board', president: 'President',
                              treasurer: 'Treasurer', secretary: 'Secretary', member: 'Member' };
        const _ptone = m.user_role === 'super_admin' ? 'gold'
          : m.user_role === 'admin' ? 'info'
          : m.position === 'honorary' ? 'honorary'
          : ['gestao','board','president','treasurer','secretary'].includes(m.position) ? 'info'
          : 'neutral';
        const _plabel = _roleLabels[m.user_role] || _posLabels[m.position] || 'Member';

        const _today = new Date(); _today.setHours(0,0,0,0);
        const _docWarnings = [];
        if (!m.is_aprc && m.arc_expiry_date) {
          const _arcExp  = new Date(m.arc_expiry_date);
          const _arcDays = Math.floor((_arcExp - _today) / 86400000);
          const _arcLbl  = m.is_tw_passport ? 'Passport' : 'ARC';
          if      (_arcDays < 0)   _docWarnings.push({ label: _arcLbl + ' Expired',       tone: 'danger'  });
          else if (_arcDays <= 60) _docWarnings.push({ label: _arcLbl + ' Expiring Soon', tone: 'warning' });
        }
        if (m.cc_expiry_date) {
          const _ccExp  = new Date(m.cc_expiry_date);
          const _ccDays = Math.floor((_ccExp - _today) / 86400000);
          if      (_ccDays < 0)   _docWarnings.push({ label: 'CC Expired',       tone: 'danger'  });
          else if (_ccDays <= 60) _docWarnings.push({ label: 'CC Expiring Soon', tone: 'warning' });
        }
      %>
      <tr class="is-clickable" onclick="location.href='/admin/members/<%= m.id %>'">
        <td>
          <div class="pta-namecell">
            <span class="pta-avatar pta-avatar--sm">
              <% if (m.photo_path) { %>
              <img src="/<%= m.photo_path.replace(/\\/g, '/') %>" alt=""
                   style="width:100%;height:100%;object-fit:cover;border-radius:inherit">
              <% } else { %><%= _initials %><% } %>
            </span>
            <span class="pta-namecell__txt">
              <span class="pta-namecell__en"><%= m.arc_name_en || (m.first_name + ' ' + m.last_name) %></span>
              <% if (m.arc_chinese_name) { %>
              <span class="pta-namecell__zh"><%= m.arc_chinese_name %></span>
              <% } %>
            </span>
          </div>
        </td>
        <td><span class="pta-id"><%= m.member_id %></span></td>
        <td><%= m.email %></td>
        <td><span class="pta-badge pta-badge--soft pta-tone-<%= _ptone %>"><%= _plabel %></span></td>
        <td>
          <% if (m.is_aprc) { %>
          <span class="pta-badge pta-badge--soft pta-tone-info">APRC</span>
          <% } else if (m.is_tw_passport) { %>
          <span class="pta-badge pta-badge--soft pta-tone-neutral">TW Passport</span>
          <% } else { %>
          <span class="pta-badge pta-badge--soft pta-tone-neutral">ARC</span>
          <% } %>
        </td>
        <td>
          <% if (m.position === 'honorary') { %>
          <%- feeBadge('honorary') %>
          <% } else { %>
          <%- feeBadge(m.fee_status) %>
          <% } %>
        </td>
        <td>
          <% if (_docWarnings.length === 0) { %>
          <span class="pta-badge pta-badge--soft pta-tone-success">No Warning</span>
          <% } else { _docWarnings.forEach(function(w) { %>
          <span class="pta-badge pta-badge--soft pta-tone-<%= w.tone %>" style="margin:.1rem .2rem .1rem 0;display:inline-block"><%= w.label %></span>
          <% }); } %>
        </td>
        <td><span class="pta-id"><%= m.join_date ? m.join_date.slice(0,10) : '—' %></span></td>
        <td onclick="event.stopPropagation()">
          <% if (canWrite) { %>
          <a href="/admin/members/<%= m.id %>/edit" class="pta-btn pta-btn--ghost pta-btn--sm" title="Edit">
            <i class="bi bi-pencil"></i>
          </a>
          <% } %>
        </td>
      </tr>
      <% }); %>
      <% if (!members.length) { %>
      <tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:3rem">No members found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
<nav style="margin-top:1rem">
  <ul class="pagination">
    <% for (let p = 1; p <= totalPages; p++) { %>
    <li class="page-item <%= p === page ? 'active' : '' %>">
      <a class="page-link" href="/admin/members?page=<%= p %>&search=<%= encodeURIComponent(search) %>&fee=<%= feeFilter %>"><%= p %></a>
    </li>
    <% } %>
  </ul>
</nav>
<% } %>

<%- include('../partials/footer') %>
