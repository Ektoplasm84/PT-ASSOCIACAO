<%- include('../partials/header') %>

<%
  var sort = (typeof sort !== 'undefined') ? sort : 'name_az';
  function feeBadge(status) {
    if (status === 'paid')
      return '<span class="pta-badge pta-badge--soft pta-tone-success"><span class="pta-badge__dot"></span>' + t('fee.status_paid') + '</span>';
    if (status === 'renewal_incoming')
      return '<span class="pta-badge pta-badge--soft pta-tone-gold"><span class="pta-badge__dot"></span>' + t('fee.status_renewal') + '</span>';
    if (status === 'unpaid')
      return '<span class="pta-badge pta-badge--soft pta-tone-danger"><span class="pta-badge__dot"></span>' + t('fee.status_unpaid') + '</span>';
    return '<span class="pta-badge pta-badge--soft pta-tone-honorary">' + t('fee.status_honorary') + '</span>';
  }
%>

<div class="pta-pagehead">
  <div class="pta-pagehead__titles">
    <h1><%= t('member.title') %> <span style="font-size:1rem;font-weight:400;color:var(--text-muted)">(<%= total %>)</span></h1>
  </div>
  <% if (canWrite) { %>
  <a href="/admin/members/new" class="pta-btn"><i class="bi bi-person-plus"></i> <%= t('member.new') %></a>
  <% } %>
</div>

<%
  function memberListUrl(overrides) {
    var p = { search: search, fee: feeFilter, sort: sort };
    Object.assign(p, overrides);
    var qs = [];
    if (p.search) qs.push('search=' + encodeURIComponent(p.search));
    if (p.fee)    qs.push('fee='    + encodeURIComponent(p.fee));
    if (p.sort && p.sort !== 'name_az') qs.push('sort=' + p.sort);
    return '/admin/members' + (qs.length ? '?' + qs.join('&') : '');
  }
%>
<div class="pta-toolbar">
  <form method="GET" action="/admin/members" class="pta-search">
    <i class="bi bi-search"></i>
    <input class="pta-control" name="search" placeholder="<%= t('member.search_placeholder') %>" value="<%= search %>">
    <% if (feeFilter) { %><input type="hidden" name="fee" value="<%= feeFilter %>"><% } %>
    <% if (sort && sort !== 'name_az') { %><input type="hidden" name="sort" value="<%= sort %>"><% } %>
  </form>
  <select class="form-select form-select-sm" style="width:auto;min-width:9rem"
          onchange="location.href=this.value" aria-label="<%= t('member.sort_label') %>">
    <%
    var _sortOpts = [
      ['name_az',     t('member.sort_name_az')],
      ['name_za',     t('member.sort_name_za')],
      ['newest',      t('member.sort_recent')],
      ['oldest',      t('member.sort_oldest')],
      ['joined_desc', t('member.sort_join_desc')],
      ['joined_asc',  t('member.sort_join_asc')],
    ];
    _sortOpts.forEach(function(opt) { %>
    <option value="<%= memberListUrl({ sort: opt[0] }) %>"
            <%= sort === opt[0] ? 'selected' : '' %>><%= opt[1] %></option>
    <% }); %>
  </select>
  <div class="pta-filterchips">
    <a href="<%= memberListUrl({ fee: '' }) %>"
       class="pta-chip <%= !feeFilter ? 'is-active' : '' %>"><%= t('member.filter_all') %></a>
    <a href="<%= memberListUrl({ fee: 'paid' }) %>"
       class="pta-chip <%= feeFilter === 'paid' ? 'is-active' : '' %>"><%= t('member.filter_paid') %></a>
    <a href="<%= memberListUrl({ fee: 'renewal_incoming' }) %>"
       class="pta-chip <%= feeFilter === 'renewal_incoming' ? 'is-active' : '' %>"><%= t('fee.status_renewal') %></a>
    <a href="<%= memberListUrl({ fee: 'unpaid' }) %>"
       class="pta-chip <%= feeFilter === 'unpaid' ? 'is-active' : '' %>"><%= t('member.filter_unpaid') %></a>
  </div>
</div>

<div class="pta-card pta-card--flush">
<div class="pta-table-wrap">
  <table class="pta-table">
    <thead>
      <tr>
        <th><%= t('member.col_member') %></th>
        <th><%= t('member.col_id') %></th>
        <th><%= t('member.col_email') %></th>
        <th><%= t('member.col_position') %></th>
        <th><%= t('member.col_id_type') %></th>
        <th><%= t('member.col_fee') %></th>
        <th><%= t('member.col_warnings') %></th>
        <th><%= t('member.col_joined') %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% members.forEach(function(m) {
        const _initials = ((m.arc_name_en || (m.first_name + ' ' + m.last_name)) || '?')
          .trim().split(/\s+/).map(function(s){return s[0]||'';}).slice(0,2).join('').toUpperCase();
        const _roleLabels = { super_admin: t('detail.role_super_admin'), admin: t('detail.role_admin') };
        const _posLabels  = { honorary: t('detail.pos_honorary'), gestao: t('detail.pos_gestao'),
                              board: t('detail.pos_board'), president: t('detail.pos_president'),
                              treasurer: t('detail.pos_treasurer'), secretary: t('detail.pos_secretary'), member: t('detail.pos_member') };
        const _ptone = m.user_role === 'super_admin' ? 'gold'
          : m.user_role === 'admin' ? 'info'
          : m.position === 'honorary' ? 'honorary'
          : ['gestao','board','president','treasurer','secretary'].includes(m.position) ? 'info'
          : 'neutral';
        const _plabel = _roleLabels[m.user_role] || _posLabels[m.position] || 'Member';

        const _today = new Date(); _today.setHours(0,0,0,0);
        const _docWarnings = [];
        if (!m.is_aprc && !m.is_tw_id && m.arc_expiry_date) {
          const _arcExp  = new Date(m.arc_expiry_date);
          const _arcDays = Math.floor((_arcExp - _today) / 86400000);
          if      (_arcDays < 0)   _docWarnings.push({ label: m.is_tw_passport ? t('member.warn_arc_expired') : t('member.warn_arc_expired'),   tone: 'danger'  });
          else if (_arcDays <= 60) _docWarnings.push({ label: m.is_tw_passport ? t('member.warn_arc_expiring') : t('member.warn_arc_expiring'), tone: 'warning' });
        }
        if (m.cc_expiry_date) {
          const _ccExp  = new Date(m.cc_expiry_date);
          const _ccDays = Math.floor((_ccExp - _today) / 86400000);
          if      (_ccDays < 0)   _docWarnings.push({ label: t('member.warn_cc_expired'),   tone: 'danger'  });
          else if (_ccDays <= 60) _docWarnings.push({ label: t('member.warn_cc_expiring'),  tone: 'warning' });
        }
      %>
      <tr class="is-clickable" onclick="location.href='/admin/members/<%= m.id %>'">
        <td>
          <div class="pta-namecell">
            <span class="pta-avatar pta-avatar--sm">
              <% if (m.photo_path) { %>
              <img src="/<%= m.photo_path.replace(/\\/g, '/') %>" alt=""
                   style="width:100%;height:100%;object-fit:cover;border-radius:inherit">
              <% } else { %><%= _initials %><% } %>
            </span>
            <span class="pta-namecell__txt">
              <span class="pta-namecell__en"><%= m.arc_name_en || (m.first_name + ' ' + m.last_name) %></span>
              <% if (m.arc_chinese_name) { %>
              <span class="pta-namecell__zh"><%= m.arc_chinese_name %></span>
              <% } %>
            </span>
          </div>
        </td>
        <td><span class="pta-id"><%= m.member_id %></span></td>
        <td><%= m.email %></td>
        <td><span class="pta-badge pta-badge--soft pta-tone-<%= _ptone %>"><%= _plabel %></span></td>
        <td>
          <% if (m.is_aprc) { %>
          <span class="pta-badge pta-badge--soft pta-tone-info"><%= t('member.id_aprc') %></span>
          <% } else if (m.is_tw_passport) { %>
          <span class="pta-badge pta-badge--soft pta-tone-neutral"><%= t('member.id_tw_passport') %></span>
          <% } else if (m.is_tw_id) { %>
          <span class="pta-badge pta-badge--soft pta-tone-neutral"><%= t('member.id_tw_id') %></span>
          <% } else { %>
          <span class="pta-badge pta-badge--soft pta-tone-neutral"><%= t('member.id_arc') %></span>
          <% } %>
        </td>
        <td>
          <% if (m.position === 'honorary') { %>
          <%- feeBadge('honorary') %>
          <% } else { %>
          <%- feeBadge(m.fee_status) %>
          <% } %>
        </td>
        <td>
          <% if (_docWarnings.length === 0) { %>
          <span class="pta-badge pta-badge--soft pta-tone-success"><%= t('member.warn_none') %></span>
          <% } else { _docWarnings.forEach(function(w) { %>
          <span class="pta-badge pta-badge--soft pta-tone-<%= w.tone %>" style="margin:.1rem .2rem .1rem 0;display:inline-block"><%= w.label %></span>
          <% }); } %>
        </td>
        <td><span class="pta-id"><%= m.join_date ? m.join_date.slice(0,10) : '—' %></span></td>
        <td onclick="event.stopPropagation()">
          <% if (canWrite) { %>
          <a href="/admin/members/<%= m.id %>/edit" class="pta-btn pta-btn--ghost pta-btn--sm" title="<%= t('common.edit') %>">
            <i class="bi bi-pencil"></i>
          </a>
          <% } %>
        </td>
      </tr>
      <% }); %>
      <% if (!members.length) { %>
      <tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:3rem"><%= t('member.no_results') %></td></tr>
      <% } %>
    </tbody>
  </table>
</div>
</div>

<% if (totalPages > 1) { %>
<nav style="margin-top:1rem">
  <ul class="pagination">
    <% for (let p = 1; p <= totalPages; p++) { %>
    <li class="page-item <%= p === page ? 'active' : '' %>">
      <a class="page-link" href="/admin/members?page=<%= p %>&search=<%= encodeURIComponent(search) %>&fee=<%= feeFilter %>"><%= p %></a>
    </li>
    <% } %>
  </ul>
</nav>
<% } %>

<%- include('../partials/footer') %>
