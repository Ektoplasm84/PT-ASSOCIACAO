<%- include('../partials/header') %>

<%
  // --- Helpers ---
  function feeBadge(status) {
    if (status === 'paid')
      return '<span class="pta-badge pta-badge--soft pta-tone-success"><span class="pta-badge__dot"></span>' + t('fee.status_paid') + '</span>';
    if (status === 'renewal_incoming')
      return '<span class="pta-badge pta-badge--soft pta-tone-gold"><span class="pta-badge__dot"></span>' + t('fee.status_renewal') + '</span>';
    if (status === 'unpaid')
      return '<span class="pta-badge pta-badge--soft pta-tone-danger"><span class="pta-badge__dot"></span>' + t('fee.status_unpaid') + '</span>';
    return '<span class="pta-badge pta-badge--soft pta-tone-honorary">' + t('fee.status_honorary') + '</span>';
  }

  function docValidity(dateStr) {
    if (!dateStr) return null;
    const daysLeft = Math.floor((new Date(dateStr) - new Date()) / 86400000);
    if (daysLeft < 0)   return { label: t('detail.doc_validity_expired'),  tone: 'danger'  };
    if (daysLeft <= 60) return { label: t('detail.doc_validity_expiring'), tone: 'warning' };
    return                     { label: t('detail.doc_validity_valid'),    tone: 'success' };
  }

  const arcValidity = (member.is_aprc || member.is_tw_id)
    ? { label: t('detail.aprc_permanent'), tone: 'info' }
    : docValidity(member.arc_expiry_date);
  const ccValidity  = docValidity(member.cc_expiry_date);
  const isHonorary  = member.user_position === 'honorary';

  const _displayName = member.arc_name_en || (member.first_name + ' ' + member.last_name);
  const _delName     = _displayName;
  const initials     = _displayName.trim().split(/\s+/).map(function(s){return s[0]||'';}).slice(0,2).join('').toUpperCase();

  const CARD_LABEL_MAP = {
    arc_front:        t('profile.card_arc_front'),
    arc_back:         t('profile.card_arc_back'),
    cc_front:         t('profile.card_cc_front'),
    cc_back:          t('profile.card_cc_back'),
    tw_passport_front:t('profile.card_tw_passport_front'),
    tw_id_front:      t('profile.card_tw_id_front'),
    tw_id_back:       t('profile.card_tw_id_back'),
  };
  const _cardSlots = ['arc_front', 'arc_back', 'cc_front', 'cc_back', 'tw_passport_front', 'tw_id_front', 'tw_id_back'];
  const cardDocs = {};
  documents.forEach(function(d){ if (d.doc_type && d.doc_type !== 'misc') cardDocs[d.doc_type] = d; });
  const miscDocs = documents.filter(function(d){ return !d.doc_type || d.doc_type === 'misc'; });
%>

<!-- Page head -->
<div class="pta-pagehead">
  <div class="pta-pagehead__titles">
    <a class="pta-chip" style="align-self:flex-start" href="/admin/members"><i class="bi bi-arrow-left"></i> <%= t('member.back_to_list') %></a>
    <h1><%= _displayName %></h1>
    <% if (member.arc_chinese_name) { %>
    <span class="pta-pagehead__sub"><%= member.arc_chinese_name %> · <span class="pta-id"><%= member.member_id %></span></span>
    <% } else { %>
    <span class="pta-pagehead__sub"><span class="pta-id"><%= member.member_id %></span></span>
    <% } %>
  </div>
  <div style="display:flex;gap:.5rem;align-items:flex-start">
    <% if (canWrite) { %>
    <a class="pta-btn pta-btn--secondary" href="/admin/members/<%= member.id %>/edit"><i class="bi bi-pencil"></i> <%= t('member.edit_btn') %></a>
    <% } %>
  </div>
</div>

<!-- Two-column detail layout -->
<div class="pta-detail">

  <!-- ── Sidebar ── -->
  <div style="display:flex;flex-direction:column;gap:1.5rem">

    <!-- Profile card -->
    <div class="pta-card">
      <div class="pta-card__body">
        <div class="pta-profilecard">
          <span class="pta-avatar pta-avatar--xl<%= isHonorary ? ' pta-avatar--honorary' : '' %>">
            <% if (member.photo_path) { %>
            <img src="/<%= member.photo_path.replace(/\\/g, '/') %>" alt=""
                 style="width:100%;height:100%;object-fit:cover;border-radius:inherit">
            <% } else { %>
            <%= initials %>
            <% } %>
          </span>
          <div>
            <div class="pta-profilecard__name"><%= _displayName %></div>
            <% if (member.arc_chinese_name) { %>
            <div class="pta-profilecard__zh"><%= member.arc_chinese_name %></div>
            <% } %>
          </div>
          <% if (isHonorary) { %>
          <span class="pta-badge pta-badge--soft pta-tone-honorary"><%= t('fee.status_honorary') %></span>
          <% } else { %>
          <%- feeBadge(member.fee_status) %>
          <% } %>
          <div class="pta-profilecard__meta">
            <%= t('member.joined') %> <%= member.join_date ? member.join_date.slice(0,10) : '—' %><br>
            <%= t('member.account_created') %> <%= member.account_created ? member.account_created.slice(0,10) : '—' %>
          </div>
          <% if (canWrite) { %>
          <% if (member.is_aprc || member.is_tw_passport || member.is_tw_id) { %>
          <div class="small text-muted mt-1 d-flex align-items-center gap-1">
            <i class="bi bi-info-circle"></i>
            <%= t('member.nia_not_available') %> <%= member.is_aprc ? 'APRC' : member.is_tw_id ? 'TW National ID' : 'Taiwan Passport' %> <%= t('member.nia_holders') %>
          </div>
          <% } else { %>
          <button class="pta-btn pta-btn--secondary pta-btn--block" id="fetchArcPhotoBtn">
            <i class="bi bi-camera"></i> <%= t('member.fetch_nia') %>
          </button>
          <% } %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Account Settings (super_admin only) -->
    <% if (isSuperAdmin) { %>
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-shield-lock"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('account.settings_title') %></span></div>
      </header>
      <div class="pta-card__body">
        <form action="/admin/members/<%= member.id %>/change-role" method="POST">
          <div class="pta-field">
            <label class="pta-field__label"><%= t('account.permission_role') %></label>
            <select name="role" class="pta-control">
              <% [
                { val: 'super_admin', label: t('detail.role_super_admin') },
                { val: 'admin',       label: t('detail.role_admin') },
                { val: 'member',      label: t('detail.role_member') },
              ].forEach(function(r) { %>
              <option value="<%= r.val %>" <%= member.user_role === r.val ? 'selected' : '' %>><%= r.label %></option>
              <% }); %>
            </select>
            <span class="pta-field__hint"><%= t('account.permission_hint') %></span>
          </div>
          <div class="pta-field">
            <label class="pta-field__label"><%= t('account.position') %></label>
            <select name="position" class="pta-control">
              <% [
                { val: 'member',    label: t('detail.pos_member') },
                { val: 'associate', label: t('detail.pos_associate') },
                { val: 'honorary',  label: t('detail.pos_honorary') },
                { val: 'gestao',    label: t('detail.pos_gestao') },
                { val: 'board',     label: t('detail.pos_board') },
                { val: 'president', label: t('detail.pos_president') },
                { val: 'treasurer', label: t('detail.pos_treasurer') },
                { val: 'secretary', label: t('detail.pos_secretary') },
              ].forEach(function(p) { %>
              <option value="<%= p.val %>" <%= member.user_position === p.val ? 'selected' : '' %>><%= p.label %></option>
              <% }); %>
            </select>
            <span class="pta-field__hint"><%= t('account.position_hint') %></span>
          </div>
          <button type="submit" class="pta-btn pta-btn--secondary pta-btn--block"
                  onclick="return confirm('Update account settings for <%= _delName.replace(/'/g, '\\\'') %>?')">
            <i class="bi bi-arrow-repeat"></i> <%= t('account.save_changes') %>
          </button>
        </form>

        <hr style="margin:1.25rem 0">

        <form action="/admin/members/<%= member.id %>/set-password" method="POST"
              id="resetPwForm" onsubmit="return validatePwReset()">
          <p class="pta-field__hint" style="margin-bottom:.75rem"><%= t('account.reset_pw_hint') %></p>
          <div class="pta-field">
            <label class="pta-field__label"><%= t('account.new_password') %></label>
            <input type="password" name="new_password" id="rpNewPw" class="pta-control"
                   minlength="6" autocomplete="new-password" required>
            <span class="pta-field__hint"><%= t('account.new_password_hint') %></span>
          </div>
          <div class="pta-field" style="margin-bottom:.75rem">
            <label class="pta-field__label"><%= t('account.confirm_password') %></label>
            <input type="password" name="confirm_password" id="rpConfirmPw" class="pta-control"
                   minlength="6" autocomplete="new-password" required>
          </div>
          <button type="submit" class="pta-btn pta-btn--danger pta-btn--block">
            <i class="bi bi-key"></i> <%= t('account.set_password') %>
          </button>
        </form>
      </div>
    </div>
    <% } %>

<script>
function validatePwReset() {
  const p = document.getElementById('rpNewPw').value;
  const c = document.getElementById('rpConfirmPw').value;
  if (p !== c) { alert('Passwords do not match.'); return false; }
  return confirm('Set a new password for <%= _delName.replace(/'/g, '\\\'') %>?');
}
</script>

    <!-- Danger Zone -->
    <% if (canWrite) { %>
    <div class="pta-card">
      <header class="pta-card__head" style="color:var(--vermelho-500,#BE3A2B)">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('account.danger_zone') %></span></div>
      </header>
      <div class="pta-card__body">
        <form action="/admin/members/<%= member.id %>/delete" method="POST"
              onsubmit="return confirm('Permanently delete <%= _delName.replace(/'/g, '\\\'') %> and all their data?')">
          <button type="submit" class="pta-btn pta-btn--danger pta-btn--block">
            <i class="bi bi-trash"></i> <%= t('member.delete_btn') %>
          </button>
        </form>
      </div>
    </div>
    <% } %>

  </div><!-- /sidebar -->

  <!-- ── Content column ── -->
  <div style="display:flex;flex-direction:column;gap:1.5rem">

    <!-- Contact -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-person-lines-fill"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('detail.contact_title') %></span></div>
      </header>
      <div class="pta-card__body">
        <dl class="pta-dl pta-dl--split">
          <dt><%= t('detail.phone') %></dt><dd class="mono"><%= member.phone || '—' %></dd>
          <dt><%= t('detail.email') %></dt><dd><%= member.email || '—' %></dd>
        </dl>
        <div class="pta-fieldset">
          <div>
            <div class="pta-fieldset__lbl"><%= t('detail.address_zh') %></div>
            <div class="pta-fieldset__val"><%= member.address_zh || '—' %></div>
          </div>
          <div>
            <div class="pta-fieldset__lbl"><%= t('detail.address_en') %></div>
            <div class="pta-fieldset__val"><%= member.address || '—' %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Membership & Fees -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-card-checklist"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('detail.membership_title') %></span></div>
      </header>
      <div class="pta-card__body">
        <dl class="pta-dl pta-dl--split">
          <dt><%= t('detail.member_id') %></dt><dd class="mono"><%= member.member_id %></dd>
          <dt><%= t('detail.join_date') %></dt><dd class="mono"><%= member.join_date ? member.join_date.slice(0,10) : '—' %></dd>
          <% if (isHonorary) { %>
          <dt><%= t('fee.status_honorary') %></dt><dd><span class="pta-badge pta-badge--soft pta-tone-honorary"><%= t('fee.status_honorary') %></span></dd>
          <% } else { %>
          <dt><%= t('fee.amount') %></dt><dd>
            <% if (member.fee_amount === 0) { %><%= t('fee.status_honorary') %><% } else { %>
            <span data-esc-twd="<%= member.fee_amount || 300 %>"><span class="esc-amt"><%= member.fee_amount || 300 %></span> <span class="js-esc-twd">TWD</span></span>
            <% } %>
          </dd>
          <dt><%= t('fee.last_paid') %></dt><dd class="mono"><%= member.fee_last_paid ? member.fee_last_paid.slice(0,10) : '—' %></dd>
          <dt><%= t('fee.valid_until') %></dt><dd class="mono"><%= member.fee_valid_until ? member.fee_valid_until.slice(0,10) : '—' %></dd>
          <dt><%= t('profile.fee_status') %></dt><dd><%- feeBadge(member.fee_status) %></dd>
          <% } %>
        </dl>

        <% if (canViewAll && !isHonorary) { %>
        <hr style="margin:1rem 0;border-color:var(--surface-sunken,#d6d1c4)">
        <p class="text-uppercase text-muted small fw-semibold mb-2" style="letter-spacing:.05em"><%= t('fee.update_payment') %></p>
        <form action="/admin/members/<%= member.id %>/fee" method="POST">
          <div style="display:flex;flex-wrap:wrap;gap:.5rem;align-items:flex-end">
            <div class="pta-field">
              <label class="pta-field__label"><%= t('fee.annual_fee') %></label>
              <select name="fee_amount" class="pta-control">
                <option value="300" <%= (member.fee_amount || 300) === 300 ? 'selected' : '' %>>300 TWD</option>
                <option value="0"   <%= member.fee_amount === 0 ? 'selected' : '' %>><%= t('fee.honorary_option') %></option>
              </select>
            </div>
            <div class="pta-field">
              <label class="pta-field__label"><%= t('fee.date_last_paid') %></label>
              <input type="date" name="fee_last_paid" class="pta-control"
                     value="<%= member.fee_last_paid ? member.fee_last_paid.slice(0,10) : '' %>">
            </div>
            <button type="submit" class="pta-btn pta-btn--secondary">
              <i class="bi bi-check-circle"></i> <%= t('fee.save_btn') %>
            </button>
          </div>
        </form>
        <% } %>
      </div>
    </div>

    <!-- Residence — ARC -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-person-vcard"></i>
        <div class="pta-card__titles">
          <span class="pta-card__eyebrow"><%= member.is_aprc ? t('detail.arc_title_aprc') : member.is_tw_passport ? t('detail.arc_title_passport') : member.is_tw_id ? t('detail.arc_title_tw_id') : t('detail.arc_title_arc') %></span>
          <span class="pta-card__title">Residence — <%= member.is_aprc ? t('detail.arc_section_aprc') : member.is_tw_passport ? t('detail.arc_section_passport') : member.is_tw_id ? t('detail.arc_section_tw_id') : t('detail.arc_section_arc') %></span>
        </div>
      </header>
      <div class="pta-card__body">
        <dl class="pta-dl pta-dl--split">
          <% if (!member.is_tw_passport && !member.is_tw_id) { %>
          <dt><%= t('detail.arc_number') %></dt><dd class="mono"><%= member.arc_number || '—' %></dd>
          <% } %>
          <% if (member.is_tw_id || member.is_tw_passport) { %>
          <dt><%= t('form.tw_id_number') %></dt><dd class="mono"><%= member.tw_id_number || '—' %></dd>
          <% } %>
          <% if (!member.is_tw_passport && !member.is_tw_id) { %>
          <dt><%= t('detail.serial_no') %></dt><dd class="mono"><%= member.arc_serial_number || '—' %></dd>
          <% } %>
          <% if (!member.is_tw_id) { %>
          <dt><%= t('detail.english_name') %></dt><dd><%= member.arc_name_en || '—' %></dd>
          <% } %>
          <dt><%= t('detail.chinese_name') %></dt><dd><%= member.arc_chinese_name || '—' %></dd>
          <% if (!member.is_tw_id) { %>
          <dt><%= member.is_tw_passport ? t('form.tw_passport_number') : t('detail.passport_no') %></dt><dd class="mono"><%= member.passport_number || '—' %></dd>
          <% } %>
          <dt><%= t('detail.issue_date') %></dt><dd class="mono"><%= member.arc_issue_date ? member.arc_issue_date.slice(0,10) : '—' %></dd>
          <% if (!member.is_tw_id) { %>
          <dt><%= member.is_tw_passport ? t('detail.passport_expiry') : t('detail.expiry_date') %></dt>
          <dd class="mono">
            <% if (member.is_aprc) { %><%= t('detail.permanent') %><% } else { %><%= member.arc_expiry_date ? member.arc_expiry_date.slice(0,10) : '—' %><% } %>
            <% if (arcValidity) { %>
            <span class="pta-badge pta-badge--soft pta-tone-<%= arcValidity.tone %>" style="margin-left:.4rem"><%= arcValidity.label %></span>
            <% } %>
          </dd>
          <% } %>
          <% if (member.date_of_birth || member.gender) { %>
          <dt><%= t('detail.date_of_birth') %></dt><dd class="mono"><%= member.date_of_birth ? member.date_of_birth.slice(0,10) : '—' %></dd>
          <dt><%= t('detail.gender') %></dt><dd><%= member.gender || '—' %></dd>
          <% } %>
          <% if (member.is_tw_id || member.is_tw_passport) { %>
          <dt><%= t('detail.birthplace_tw') %></dt><dd><%= member.birthplace_tw || '—' %></dd>
          <% } %>
        </dl>
      </div>
    </div>

    <!-- Cartão de Cidadão -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-credit-card"></i>
        <div class="pta-card__titles">
          <span class="pta-card__eyebrow"><%= t('detail.cc_eyebrow') %></span>
          <span class="pta-card__title"><%= t('detail.cc_title') %></span>
        </div>
      </header>
      <div class="pta-card__body">
        <dl class="pta-dl pta-dl--split">
          <dt><%= t('detail.cc_number') %></dt><dd class="mono"><%= member.cc_number || '—' %></dd>
          <dt><%= t('detail.nif') %></dt><dd class="mono"><%= member.nif || '—' %></dd>
          <dt><%= t('detail.niss') %></dt><dd class="mono"><%= member.niss || '—' %></dd>
          <dt><%= t('detail.expiry_date') %></dt>
          <dd class="mono">
            <%= member.cc_expiry_date ? member.cc_expiry_date.slice(0,10) : '—' %>
            <% if (ccValidity) { %>
            <span class="pta-badge pta-badge--soft pta-tone-<%= ccValidity.tone %>" style="margin-left:.4rem"><%= ccValidity.label %></span>
            <% } %>
          </dd>
        </dl>
      </div>
    </div>

    <!-- Notes -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-chat-left-text"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('detail.notes_title') %></span></div>
      </header>
      <div class="pta-card__body">
        <% if (member.notes) { %>
        <p class="mb-0" style="white-space:pre-wrap"><%= member.notes %></p>
        <% } else { %>
        <p class="mb-0" style="color:var(--text-muted)"><%= t('detail.no_notes') %></p>
        <% } %>
      </div>
    </div>

    <!-- Documents -->
    <div class="pta-card">
      <header class="pta-card__head">
        <i class="bi bi-folder2-open"></i>
        <div class="pta-card__titles"><span class="pta-card__title"><%= t('detail.docs_title') %></span></div>
      </header>
      <div class="pta-card__body">

        <!-- Identity card slots (read-only — upload & scan from Edit page) -->
        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-uppercase text-muted small fw-semibold mb-0" style="letter-spacing:.05em"><%= t('detail.identity_cards') %></p>
          <% if (canWrite) { %>
          <a href="/admin/members/<%= member.id %>/edit" class="pta-btn pta-btn--ghost pta-btn--sm">
            <i class="bi bi-upload"></i> <%= t('detail.upload_scan_cards') %>
          </a>
          <% } %>
        </div>
        <div class="pta-docslots">
          <% for (const type of _cardSlots) { %>
          <%   const label = CARD_LABEL_MAP[type]; %>
          <%   const doc   = cardDocs[type]; %>
          <div class="pta-docslot">
            <div class="small fw-semibold" style="color:var(--text-muted);margin-bottom:.4rem"><%= label %></div>
            <% if (doc) { %>
              <div style="flex:1;display:flex;align-items:center;justify-content:center;margin-bottom:.5rem">
                <% if (doc.thumb_path) { %>
                <img src="/<%= doc.thumb_path.replace(/\\/g, '/') %>"
                     class="img-fluid rounded" style="max-height:75px;max-width:100%;object-fit:contain;cursor:pointer"
                     onclick="openImageModal('/admin/members/<%= member.id %>/documents/<%= doc.id %>/view','/admin/members/<%= member.id %>/documents/<%= doc.id %>/download','<%= label %>')"
                     title="Click to view">
                <% } else { %>
                <i class="bi bi-file-image" style="font-size:2.2rem;color:var(--text-muted)"></i>
                <% } %>
              </div>
              <div style="display:flex;gap:.25rem;flex-wrap:wrap;justify-content:center;margin-bottom:.25rem">
                <a href="/admin/members/<%= member.id %>/documents/<%= doc.id %>/download"
                   class="pta-btn pta-btn--ghost pta-btn--sm">
                  <i class="bi bi-download"></i>
                </a>
                <% if (canWrite) { %>
                <form method="POST"
                      action="/admin/members/<%= member.id %>/documents/<%= doc.id %>/delete"
                      onsubmit="return confirm('Delete this card image?')" class="d-inline">
                  <button type="submit" class="pta-btn pta-btn--ghost pta-btn--sm" style="color:var(--vermelho-500,#BE3A2B)">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>
            <% } else { %>
              <div style="flex:1;display:flex;align-items:center;justify-content:center">
                <i class="bi bi-card-image" style="font-size:2.5rem;color:var(--text-muted)"></i>
              </div>
              <p class="small text-muted text-center mb-0" style="font-size:.75rem"><%= t('detail.no_card_yet') %></p>
            <% } %>
          </div>
          <% } %>
        </div>

        <hr style="margin:1.25rem 0;border-color:var(--surface-sunken,#d6d1c4)">

        <!-- Miscellaneous documents -->
        <p class="text-uppercase text-muted small fw-semibold mb-2" style="letter-spacing:.05em"><%= t('detail.miscellaneous') %></p>
        <% if (miscDocs.length) { %>
        <ul class="list-group list-group-flush mb-3">
          <% miscDocs.forEach(function(doc) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center px-0">
            <span class="d-flex align-items-center gap-2">
              <% if (doc.thumb_path) { %>
              <img src="/<%= doc.thumb_path.replace(/\\/g, '/') %>"
                   style="height:40px;width:40px;object-fit:cover;cursor:pointer" class="rounded border"
                   onclick="openImageModal('/admin/members/<%= member.id %>/documents/<%= doc.id %>/view','/admin/members/<%= member.id %>/documents/<%= doc.id %>/download','<%= doc.original_name %>')"
                   title="Click to view">
              <% } else { %>
              <i class="bi bi-file-earmark text-secondary fs-4"></i>
              <% } %>
              <span>
                <div class="small fw-semibold"><%= doc.original_name %></div>
                <div class="pta-id" style="font-size:.75rem"><%= doc.uploaded_at.slice(0,10) %></div>
              </span>
            </span>
            <div class="d-flex gap-2">
              <a href="/admin/members/<%= member.id %>/documents/<%= doc.id %>/download"
                 class="pta-btn pta-btn--secondary pta-btn--sm"><i class="bi bi-download"></i></a>
              <% if (canWrite) { %>
              <form action="/admin/members/<%= member.id %>/documents/<%= doc.id %>/delete"
                    method="POST" onsubmit="return confirm('Delete this document?')">
                <button class="pta-btn pta-btn--ghost pta-btn--sm" type="submit"
                        style="color:var(--vermelho-500,#BE3A2B)"><i class="bi bi-trash"></i></button>
              </form>
              <% } %>
            </div>
          </li>
          <% }); %>
        </ul>
        <% } else { %>
        <p class="text-muted small mb-3"><%= t('detail.no_misc_docs') %></p>
        <% } %>

        <% if (canWrite) { %>
        <form action="/admin/members/<%= member.id %>/documents" method="POST" enctype="multipart/form-data">
          <div class="input-group">
            <input type="file" name="documents" class="form-control" multiple
                   accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.txt">
            <button class="pta-btn" type="submit">
              <i class="bi bi-upload"></i> <%= t('common.upload') %>
            </button>
          </div>
          <div class="form-text"><%= t('detail.upload_docs_hint') %></div>
        </form>
        <% } %>

      </div>
    </div>

  </div><!-- /content column -->
</div><!-- /pta-detail -->


<!-- ─────────────────────────────────────────────── -->
<!-- Image Lightbox Modal                           -->
<!-- ─────────────────────────────────────────────── -->
<div class="modal fade" id="imageViewModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title mb-0" id="imageViewModalTitle"></h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-2">
        <img id="imageViewModalImg" src="" alt="" class="img-fluid rounded" style="max-height:75vh">
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        <a id="imageViewModalDownload" href="#" class="btn btn-primary btn-sm">
          <i class="bi bi-download"></i> Download
        </a>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var _imgModal = null;
  function imgModal() {
    if (!_imgModal) _imgModal = new bootstrap.Modal(document.getElementById('imageViewModal'));
    return _imgModal;
  }
  window.openImageModal = function (viewUrl, downloadUrl, label) {
    document.getElementById('imageViewModalTitle').textContent = label;
    document.getElementById('imageViewModalImg').src = viewUrl;
    document.getElementById('imageViewModalDownload').href = downloadUrl;
    imgModal().show();
  };
})();
</script>


<!-- ─────────────────────────────────────────────── -->
<!-- NIA Photo Modal                                -->
<!-- ─────────────────────────────────────────────── -->
<div class="modal fade" id="arcPhotoModal" tabindex="-1" aria-labelledby="arcPhotoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="arcPhotoModalLabel">Fetch Official NIA Photo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="arcSpinner" class="text-center py-3">
          <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
          <p class="small text-muted mt-2 mb-0" id="arcSpinnerMsg">Contacting NIA&hellip;</p>
        </div>
        <div id="arcFetchError" style="display:none" class="text-center py-2">
          <p class="small text-danger mb-2" id="arcFetchErrMsg"></p>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="arcRetryBtn">
            <i class="bi bi-arrow-clockwise"></i> Try again
          </button>
        </div>
        <div id="arcCaptchaArea" style="display:none">
          <p class="small text-muted mb-2">
            Enter the code shown below. NIA returns the official photo when all ARC fields match exactly.
          </p>
          <div class="text-center mb-3">
            <img id="arcCaptchaImg" src="" alt="CAPTCHA" class="border rounded"
                 style="height:52px;cursor:pointer" title="Click to reload">
            <div>
              <button type="button" class="btn btn-link btn-sm p-0 mt-1" id="reloadCaptchaBtn">
                <i class="bi bi-arrow-clockwise"></i> New code
              </button>
            </div>
          </div>
          <input type="text" id="arcCaptchaInput" class="form-control text-center fw-bold"
                 placeholder="Type code here" maxlength="12" autocomplete="off" spellcheck="false">
          <p class="text-danger small mt-2 mb-0" id="arcError" style="display:none"></p>
        </div>
        <div id="arcSuccess" class="text-center py-3" style="display:none">
          <i class="bi bi-check-circle-fill text-success" style="font-size:2rem"></i>
          <p class="mt-2 mb-0">Photo saved &mdash; reloading&hellip;</p>
        </div>
      </div>
      <div class="modal-footer" id="arcFooter" style="display:none">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" id="submitCaptchaBtn">
          <i class="bi bi-download"></i> Fetch Photo
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var MEMBER_ID    = <%= member.id %>;
  var currentToken = null;

  var elSpinner    = document.getElementById('arcSpinner');
  var elSpinnerMsg = document.getElementById('arcSpinnerMsg');
  var elFetchErr   = document.getElementById('arcFetchError');
  var elFetchErrMsg= document.getElementById('arcFetchErrMsg');
  var elCaptcha    = document.getElementById('arcCaptchaArea');
  var elSuccess    = document.getElementById('arcSuccess');
  var elFooter     = document.getElementById('arcFooter');
  var elError      = document.getElementById('arcError');
  var elInput      = document.getElementById('arcCaptchaInput');
  var elImg        = document.getElementById('arcCaptchaImg');
  var elSubmit     = document.getElementById('submitCaptchaBtn');

  function setState(s) {
    elSpinner.style.display  = s === 'loading'  ? 'block' : 'none';
    elFetchErr.style.display = s === 'fetcherr' ? 'block' : 'none';
    elCaptcha.style.display  = s === 'captcha'  ? 'block' : 'none';
    elSuccess.style.display  = s === 'success'  ? 'block' : 'none';
    elFooter.style.display   = s === 'captcha'  ? 'flex'  : 'none';
  }

  function loadCaptcha() {
    setState('loading');
    elSpinnerMsg.textContent = 'Contacting NIA…';
    currentToken = null;
    elError.style.display = 'none';

    fetch('/admin/members/' + MEMBER_ID + '/arc-captcha')
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        if (!res.ok || res.d.error) {
          elFetchErrMsg.textContent = res.d.error || 'Failed to load captcha';
          setState('fetcherr');
          return;
        }
        currentToken = res.d.token;
        elImg.src = res.d.captchaImage;
        setState('captcha');
        elInput.value = '';
        elInput.focus();
      })
      .catch(function (e) {
        elFetchErrMsg.textContent = 'Network error: ' + e.message;
        setState('fetcherr');
      });
  }

  function silentRefreshCaptcha() {
    currentToken = null;
    elImg.style.opacity = '0.4';
    fetch('/admin/members/' + MEMBER_ID + '/arc-captcha')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.error) return;
        currentToken = d.token;
        elImg.src = d.captchaImage;
        elInput.value = '';
      })
      .finally(function () { elImg.style.opacity = '1'; });
  }

  <% if (canWrite) { %>
  document.getElementById('fetchArcPhotoBtn').addEventListener('click', function () {
    new bootstrap.Modal(document.getElementById('arcPhotoModal')).show();
    loadCaptcha();
  });
  <% } %>

  document.getElementById('reloadCaptchaBtn').addEventListener('click', loadCaptcha);
  elImg.addEventListener('click', loadCaptcha);

  elSubmit.addEventListener('click', function () {
    var answer = elInput.value.trim();
    if (!answer) { elInput.focus(); return; }
    if (!currentToken) { loadCaptcha(); return; }

    elSubmit.disabled = true;
    elError.style.display = 'none';
    setState('loading');
    elSpinnerMsg.textContent = 'Verifying with NIA…';

    fetch('/admin/members/' + MEMBER_ID + '/arc-fetch-photo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: currentToken, captchaAnswer: answer }),
    })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.success) {
          setState('success');
          setTimeout(function () { window.location.reload(); }, 1200);
        } else {
          setState('captcha');
          elError.textContent = d.error || 'Unknown error';
          elError.style.display = 'block';
          if (d.refreshCaptcha) silentRefreshCaptcha();
        }
      })
      .catch(function (e) {
        setState('captcha');
        elError.textContent = 'Network error: ' + e.message;
        elError.style.display = 'block';
      })
      .finally(function () {
        elSubmit.disabled = false;
      });
  });

  elInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') elSubmit.click();
  });

  document.getElementById('arcRetryBtn').addEventListener('click', loadCaptcha);
})();
</script>

